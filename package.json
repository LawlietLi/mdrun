{
  "name": "@leyohli/mdrun",
  "version": "0.1.0",
  "description": "A Markdown-based task runner — documentation first, commands second",
  "type": "module",
  "bin": {
    "mdrun": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "markdown",
    "task-runner",
    "cli",
    "build-tool",
    "mdrun"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liyiheng/mdrun.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
